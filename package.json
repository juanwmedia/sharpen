{
  "name": "sharpen",
  "version": "0.1.5",
  "description": "Sharpen by FrontendLeap. Timed Git challenges in your browser, with a Socratic AI mentor. A Claude Code plugin.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "start": "tsx --import ./scenarios/package/register-md.ts server/index.ts",
    "test": "vitest run",
    "release": "node scripts/release.mjs",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "express": "^5.1.0",
    "isomorphic-git": "^1.38.0",
    "just-bash": "^2.14.5",
    "tsx": "^4.23.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@wterm/core": "^0.3.0",
    "@wterm/dom": "^0.3.0",
    "@wterm/just-bash": "^0.3.0",
    "esbuild": "^0.28.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.3.7"
  }
}
