{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "jsx": "preserve",
    "paths": {
      "@engine/*": ["./engine/*"],
      "@challenges/*": ["./challenges/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*",
    "engine/**/*",
    "server/**/*",
    "challenges/**/*",
    "test/**/*",
    "vite.config.ts",
    "challenges/package/md-shim.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
